APP_NAME=SmartFit AI Backend
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=["*"]
DEFAULT_USER_HEIGHT_CM=170.0
MEASUREMENT_ROUND_DIGITS=2
CONSENT_VERSION=v1
AUTO_DELETE_UPLOADED_IMAGES=true
AUTH_TOKEN_SECRET=smartfit-dev-secret-change-me
