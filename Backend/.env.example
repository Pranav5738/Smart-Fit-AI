APP_NAME=SmartFit AI Backend
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DEFAULT_USER_HEIGHT_CM=170.0
MEASUREMENT_ROUND_DIGITS=2
CONSENT_VERSION=v1
AUTO_DELETE_UPLOADED_IMAGES=true
AUTH_TOKEN_SECRET=replace-with-a-random-32-plus-char-secret
AUTH_ACCESS_TOKEN_MINUTES=20
AUTH_REFRESH_TOKEN_DAYS=14
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=10
AUTH_ATTEMPT_WINDOW_MINUTES=15
MODEL_PATH=models/size_model.pkl
TRYON_ASSETS_DIR=static/clothing
CATALOG_PATH=static/catalog/products.csv
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
