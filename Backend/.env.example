AUTH_REFRESH_TOKEN_DAYS=14
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=10
AUTH_ATTEMPT_WINDOW_MINUTES=15
MODEL_PATH=models/size_model.pkl
TRYON_ASSETS_DIR=static/clothing
CATALOG_PATH=static/catalog/products.csv
DATA_STORE_PATH=model_artifacts/profile_store.db
